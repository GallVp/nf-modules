// According to the issue https://github.com/fenderglass/Flye/issues/164
// Some fluctuations are expected because of the heuristics
// Here we check the that test.assembly_info.txt contains at least one contig

nextflow_process {

    name "Test Process FLYE"
    script "../main.nf"
    process "FLYE"
    config "./nextflow.config"

    tag "flye"
    tag "modules"
    tag "modules_nfcore"

    test("flye_pacbio_raw") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/fastq/test_hifi.fastq.gz', checkIfExists: true)
                ]
                input[1] = "--pacbio-raw"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.fasta[0][1] ==~ '.*/test.assembly.fasta.gz' },
                { assert process.out.gfa[0][1] ==~ '.*/test.assembly_graph.gfa.gz' },
                { assert process.out.gv[0][1] ==~ '.*/test.assembly_graph.gv.gz' },
                { assert process.out.log[0][1] ==~ '.*/test.flye.log' },
                { assert process.out.txt[0][1] ==~ '.*/test.assembly_info.txt' },
                { assert process.out.json[0][1] ==~ '.*/test.params.json' },

                // check for contig_1 in assembly_info
                { assert path(process.out.txt[0][1]).text =~ /contig_1/ },
                // Check if test.params.json matches
                { assert snapshot(
                    process.out.json,
                    process.out.versions
                    ).match()
                }
            )
        }

    }


